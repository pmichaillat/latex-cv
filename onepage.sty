
% ---- Adjust page layout ----

\geometry{top=0.8in, left=1.2in, right=1.2in, bottom=1in, footskip=0.8in}

% ---- Adjust line spacing ----

\setstretch{1}

% ---- Format lists ----

% Format itemized lists
\setlist[itemize, 1]{leftmargin=2em, label=\color{gray}{\textendash}, itemsep=2.5pt, parsep=0pt, topsep=0pt}

% Format numbered lists
\setlist[enumerate, 1]{leftmargin=2em, label=\color{gray}{\arabic*.}, itemsep=2.5pt, parsep=0pt, topsep=0pt}